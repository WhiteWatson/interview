# ---- 豆包流式语音识别 2.0 (火山引擎) ----
# 新版控制台 API Key（WebSocket 握手头 X-Api-Key）
VOLC_ASR_API_KEY=paste-your-asr-api-key-here
# 资源 ID：小时版 volc.seedasr.sauc.duration / 并发版 volc.seedasr.sauc.concurrent
VOLC_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
# 双向流式（优化版）接口地址
VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# ---- 豆包大模型 (火山方舟, OpenAI 兼容) ----
ARK_API_KEY=paste-your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Doubao-Seed-2.0-mini 推理接入点 ID
ARK_MODEL_ID=your-endpoint-id

# ---- 服务 ----
PORT=3001
